      "turns": [
        {
          "user_msg": "cualquier cosa (deberia ignorarse porque ya está lockeado)",
          "expect": {
            "action": "noop",
            "state": {
              "locked_route": "TPMS",
              "estimated_route": "TPMS",
              "confidence": 0.9,
              "attempts": 1
            }
          }
        }
      ]
    }
  ]
