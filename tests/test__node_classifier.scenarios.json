{
  "node_ref": "app.core.graph.classifier.nodes:node__classify_user_intent",
  "scenarios": [
    {
      "id": "Scenario_1",
      "title": "Support + route mention -> direct lock (no LLM)",
      "tags": [
        "routing",
        "heuristic",
        "no_llm",
        "tpms"
      ],
      "setup": {
        "initial_state": {
          "routing_attempts": 0
        }
      },
      "turns": [
        {
          "user_msg": "soporte tpms, no conecta el sensor",
          "expect": {
            "action": "lock_route",
            "state": {
              "locked_route": "TPMS",
              "estimated_route": "TPMS",
              "routing_attempts": 0,
              "confidence": 1.0
            }
          }
        }
      ]
    },
    {
      "id": "Scenario_2",
      "title": "LLM classifier: high confidence -> lock route",
      "tags": [
        "llm",
        "high_confidence"
      ],
      "setup": {
        "initial_state": {
          "routing_attempts": 0
        }
      },
      "turns": [
        {
          "user_msg": "Mi aire acondicionado no enfría completamente.",
          "expect": {
            "one_of": [
              {
                "action": "lock_route",
                "state": {
                  "locked_route": "AA",
                  "estimated_route": "AA",
                  "confidence_min": 0.8
                }
              },
              {
                "action": "ask_clarifier",
                "state": {
                  "locked_route": null,
                  "estimated_route": "AA"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "Scenario_3",
      "title": "LLM classifier: low confidence -> ask clarifier",
      "tags": [
        "llm",
        "low_confidence",
        "ambiguous"
      ],
      "setup": {
        "initial_state": {
          "routing_attempts": 0
        }
      },
      "turns": [
        {
          "user_msg": "Tengo una consulta sobre un producto.",
          "expect": {
            "action": "ask_clarifier",
            "state": {
              "locked_route": null,
              "routing_attempts": 1,
              "confidence_min": 0.0,
              "confidence_max": 0.7
            }
          }
        }
      ]
    }
  ]
}