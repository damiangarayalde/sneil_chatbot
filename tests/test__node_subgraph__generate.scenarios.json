{
    "node_ref": "app.core.graph.route_handler.factory_and_nodes:make_route_subgraph",
    "route_id": "AA",
    "node_name": "generate",
    "scenarios": [
        {
            "id": "generate_1",
            "title": "Topic switch clears lock, solve_attempts, confidence, and retrieved",
            "tags": [
                "route_subgraph",
                "generate",
                "requires_mock_llm",
                "topic_switch"
            ],
            "setup": {
                "route_id": "TPMS",
                "initial_state": {
                    "solve_attempts": 2,
                    "locked_route": "TPMS",
                    "confidence": 0.7,
                    "retrieved": [
                        {
                            "page_content": "tpms doc"
                        }
                    ],
                    "messages": [
                        {
                            "type": "human",
                            "content": "Ahora quiero ver aires acondicionados"
                        }
                    ]
                },
                "mocks": {
                    "llm_output": {
                        "is_topic_switch": true,
                        "answer": "",
                        "increment_solve_attempts": false
                    }
                }
            },
            "turns": [
                {
                    "user_msg": "Ahora quiero ver aires acondicionados",
                    "expect": {
                        "action": "noop",
                        "state": {
                            "locked_route": null,
                            "solve_attempts": 0,
                            "confidence": 0,
                            "retrieved": null
                        }
                    }
                }
            ]
        },
        {
            "id": "generate_2",
            "title": "Normal answer increments solve_attempts and returns AI message",
            "tags": [
                "route_subgraph",
                "generate",
                "requires_mock_llm",
                "deterministic_with_stub"
            ],
            "setup": {
                "route_id": "AA",
                "initial_state": {
                    "solve_attempts": 0,
                    "locked_route": "AA",
                    "retrieved": [
                        {
                            "page_content": "aa doc"
                        }
                    ],
                    "messages": [
                        {
                            "type": "human",
                            "content": "No enfría y hace ruido"
                        }
                    ]
                },
                "mocks": {
                    "llm_output": {
                        "is_topic_switch": false,
                        "answer": "Para diagnosticar la falla, revisá el filtro de aire y el ventilador del condensador.",
                        "increment_solve_attempts": true
                    }
                }
            },
            "turns": [
                {
                    "user_msg": "No enfría y hace ruido",
                    "expect": {
                        "state": {
                            "solve_attempts": 1,
                            "locked_route": "AA"
                        },
                        "assistant": {
                            "contains": [
                                "diagnosticar",
                                "falla"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "id": "generate_3",
            "title": "Empty answer triggers fallback message and still increments solve_attempts",
            "tags": [
                "route_subgraph",
                "generate",
                "requires_mock_llm",
                "fallback"
            ],
            "setup": {
                "route_id": "AA",
                "initial_state": {
                    "solve_attempts": 1,
                    "locked_route": "AA",
                    "retrieved": [
                        {
                            "page_content": "aa doc"
                        }
                    ],
                    "messages": [
                        {
                            "type": "human",
                            "content": "ok"
                        }
                    ]
                },
                "mocks": {
                    "llm_output": {
                        "is_topic_switch": false,
                        "answer": "",
                        "increment_solve_attempts": true
                    }
                }
            },
            "turns": [
                {
                    "user_msg": "ok",
                    "expect": {
                        "state": {
                            "solve_attempts": 2
                        },
                        "assistant": {
                            "contains": [
                                "¿Podés darme un poco más de detalle"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}