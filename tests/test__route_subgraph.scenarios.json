            "escalated_to_human": true,
            "attempts": 0
          }
        }
      }
    ]
  },
  {
    "id": "Scenario__2A",
    "title": "first attempt (0), vague -> clarifying question, no RAG, no increment",
    "route_id": "TPMS",
    "setup": {
      "initial_state": {
        "attempts": 0
      }
    },
    "turns": [
      {
        "user_msg": "Necesito ayuda con TPMS",
        "expect": {
          "action": "ask_clarifier",
          "state": {
            "locked_route": "TPMS",
            "attempts": 0,
            "rag_ran": false
          }
        }
      }
    ]
  },
  {
    "id": "Scenario__2B",
    "title": "first attempt (0), problem -> answer + confirmation, attempts +1",
    "route_id": "TPMS",
    "setup": {
      "initial_state": {
        "attempts": 0
      }
    },
    "turns": [
      {
        "user_msg": "El TPMS no conecta el sensor y me marca error.",
        "expect": {
          "state": {
            "locked_route": "TPMS",
            "attempts": 1
          }
        }
      }
    ]
  },
  {
    "id": "Scenario__3",
    "title": "attempts=1 (<max) -> answer + confirmation, attempts becomes 2",
    "route_id": "TPMS",
    "setup": {
      "initial_state": {
        "attempts": 1
      }
    },
    "turns": [
      {
        "user_msg": "Sigue sin conectar. Ya reinicié y cambié la pila del sensor.",
        "expect": {
          "state": {
            "locked_route": "TPMS",
            "attempts": 2
          }
        }
      }
    ]
  }
